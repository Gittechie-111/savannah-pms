              "raw": "{\n  \"Body\": {\n    \"stkCallback\": {\n      \"ResultCode\": \"0\",\n      \"ResultDesc\": \"The service request is processed successfully.\",\n      \"CheckoutRequestID\": \"{{checkout_request_id}}\",\n      \"CallbackMetadata\": {\n        \"Item\": [\n          {\n            \"Name\": \"Amount\",\n            \"Value\": 35000\n          },\n          {\n            \"Name\": \"MpesaReceiptNumber\",\n            \"Value\": \"ABC123XYZ\"\n          },\n          {\n            \"Name\": \"PhoneNumber\",\n            \"Value\": \"254708374149\"\n          }\n        ]\n      }\n    }\n  }\n}"
            },
